# 优先复用工作区里已存在的 DepthAnything-3 本地仓库。
# 这样在 GitHub 不可达时, `setup-depth-anything-3` 仍能从本地镜像同步目标 commit。
export DEPTH_ANYTHING_3_LOCAL_REPO=/workspace/depth-anything-3

# 如果当前机器已经有现成的 glm 头文件树,可以在这里显式指定。
# 留空时, `install_gsplat.sh` 会自动在常见工作区路径里尝试搜索可复用副本。
export GSPLAT_GLM_LOCAL_DIR=

# tiny-cuda-nn 默认缓存到 `/tmp`,避免在仓库工作树内 clone / checkout 过慢。
# 如果你希望复用别的位置,可以把这个变量改成一个已存在或可创建的本地目录。
export TINYCUDANN_LOCAL_REPO=/tmp/video_to_world-tiny-cuda-nn

# tiny-cuda-nn 依赖 tarball 的缓存目录。
# 保持固定路径后,大文件下载在多次重跑之间也能继续续传。
export TINYCUDANN_ARCHIVE_CACHE_DIR=/tmp/video_to_world-tinycudann-archives

# 可选覆盖自动探测到的 CUDA toolkit 根目录。
# 默认先指向这台机器最常见的安装位置; 如果你的 CUDA 在别处,改这里即可。
export CUDA_HOME=/usr/local/cuda

# 默认仍会清理失效的 loopback 代理。
# 如果你确认本地代理可用,例如 127.0.0.1:7890,把它改成 1 后再执行 `pixi run ...`。
export PIXI_KEEP_LOOPBACK_PROXY=0
